# Server
PORT=3000
NODE_ENV=development

# JWT (로그인 토큰)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Add your env variables below
# Firebase
# GCP(Cloud Run) 배포 환경에서는 아래 변수 없이 자동으로 인증됩니다. (기본 서비스 계정 권한 부여 필요)
# 다만, 로컬에서 DB에 접근하려면 키 파일을 발급받아 Base64로 인코딩한 값을 아래 환경변수에 넣어야 합니다.
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_json_here

# Firebase Web API Key (For REST API Authentication Testing)
FIREBASE_API_KEY=your_firebase_web_api_key_here
